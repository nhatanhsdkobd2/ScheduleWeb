PORT=4000
# Kết nối PostgreSQL: dùng DATABASE_URL hoặc tách PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE
DATABASE_URL=postgres://schedule:schedule@localhost:5432/scheduleweb
# PGHOST=localhost
# PGPORT=5432
# PGUSER=schedule
# PGPASSWORD=schedule
# PGDATABASE=scheduleweb
REDIS_URL=redis://localhost:6379
EXPORT_DIR=./exports
ALLOWED_ORIGIN=http://localhost:3000
